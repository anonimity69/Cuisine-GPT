    "metadata": {
        "source": "Wikibooks Cookbook",
        "url": "https://en.wikibooks.org/wiki/Cookbook:Coconut_Chutney_(North_Indian)",
        "title": "Cookbook:Coconut Chutney (North Indian)",
        "cuisine_region": "South Asia",
        "type": "Recipe"
    },
    "ingredients": [
        "2 cups shredded fresh coconut",
        "1–2 split green chillies",
        "5 cloves garlic",
        "½ cup chopped cilantro",
        "½ teaspoon salt",
        "½ cup water"
    ],
    "procedure": [
        "Grind all ingredients well in a blender.",
        "Serve within 2 days."
    ]
}