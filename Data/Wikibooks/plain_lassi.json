        "title": "Cookbook:Plain Lassi",
        "cuisine_region": "South Asia",
        "type": "Recipe"
    },
    "ingredients": [
        "Curd (thick plain \"natural\" yogurt)",
        "Sugar",
        "Cold water"
    ],
    "procedure": [
        "Whip the curd in a bowl until loosened.",
        "Mix in a quarter as much water as curd.",
        "Sweeten with sugar to taste.",
        "Serve cold."
    ]
}