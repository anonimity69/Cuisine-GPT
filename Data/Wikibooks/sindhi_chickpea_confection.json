{
    "metadata": {
        "source": "Wikibooks Cookbook",
        "url": "https://en.wikibooks.org/wiki/Cookbook:Sindhi_Chickpea_Confection",
        "title": "Cookbook:Sindhi Chickpea Confection",
        "cuisine_region": "South Asia",
        "type": "Recipe"
    },
    "ingredients": [
        "500 g gram flour",
        "250 g ghee",
        "150 g sugar",
        "10–15 cashews, chopped",
        "10–15 almonds, chopped",
        "5–10 pistachios, chopped"
    ],
    "procedure": [
        "Heat the ghee in a pan. Add the gram flour, and stir until toasted.",
        "Remove from the heat, and stir in the sugar.",
        "Return to the heat, and stir until the sugar melts.",
        "Transfer mixture to a bowl, and garnish with nuts.",
        "Serve hot or cold."
    ]
}