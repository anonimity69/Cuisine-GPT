{
    "metadata": {
        "source": "Wikibooks Cookbook",
        "url": "https://en.wikibooks.org/wiki/Cookbook:Papaya_Lassi",
        "title": "Cookbook:Papaya Lassi",
        "cuisine_region": "South Asia",
        "type": "Recipe"
    },
    "ingredients": [
        "½ cup water",
        "4 cups plain yogurt",
        "⅔ cup honey",
        "½ teaspoon salt",
        "1 cup papaya pulp",
        "½ teaspoon ground cinnamon"
    ],
    "procedure": [
        "Combine everything in a blender.",
        "Blend until smooth."
    ]
}