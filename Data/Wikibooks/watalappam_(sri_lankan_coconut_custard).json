{
    "metadata": {
        "source": "Wikibooks Cookbook",
        "url": "https://en.wikibooks.org/wiki/Cookbook:Watalappam_(Sri_Lankan_Coconut_Custard)",
        "title": "Cookbook:Watalappam (Sri Lankan Coconut Custard)",
        "cuisine_region": "South Asia",
        "type": "Recipe"
    },
    "ingredients": [
        "2 cups thick coconut milk",
        "½ lb brown sugar (or jaggery)",
        "4 eggs",
        "1 pinch of ground cardamom (optional)",
        "3 cloves (optional)",
        "12 cashews"
    ],
    "procedure": [
        "Beat the eggs in a mixer. Add the milk, brown sugar, cardamom, and cloves to the beaten eggs. Mix well.",
        "Transfer the mixture to a pot and steam for 20 minutes. Add the cashews."
    ]
}