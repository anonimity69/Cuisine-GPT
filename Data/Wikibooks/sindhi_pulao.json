{
    "metadata": {
        "source": "Wikibooks Cookbook",
        "url": "https://en.wikibooks.org/wiki/Cookbook:Sindhi_Pulao",
        "title": "Cookbook:Sindhi Pulao",
        "cuisine_region": "South Asia",
        "type": "Recipe"
    },
    "ingredients": [
        "Oil",
        "5 medium onions, finely chopped",
        "3–5 green chiles, finely chopped",
        "Curry leaves",
        "7–10 cashews",
        "1 tbsp garam masala",
        "1 tbsp pepper",
        "1 tsp red chile powder",
        "1 bay leaf",
        "Salt to taste",
        "2 cups uncooked basmati rice"
    ],
    "procedure": [
        "Heat some oil in a pot, and add the onions. Fry until dark brown.",
        "Add the chiles, curry leaves, cashews, garam masala, pepper, chili powder, bay leaf, and salt.",
        "Add the rice and enough water to cook the rice. Simmer uncovered until all the water is absorbed.",
        "Serve hot."
    ]
}