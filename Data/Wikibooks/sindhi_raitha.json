{
    "metadata": {
        "source": "Wikibooks Cookbook",
        "url": "https://en.wikibooks.org/wiki/Cookbook:Sindhi_Raitha",
        "title": "Cookbook:Sindhi Raitha",
        "cuisine_region": "South Asia",
        "type": "Recipe"
    },
    "ingredients": [
        "100 g curd (thick plain \"natural\" yogurt)",
        "50 g finely-chopped onion",
        "2–3 pieces green chiles, finely chopped",
        "5–10 pieces chopped tomatoes",
        "2 pinches amchoor (dry mango powder)",
        "Salt to taste"
    ],
    "procedure": [
        "Combine all ingredients together.",
        "Serve cool."
    ]
}