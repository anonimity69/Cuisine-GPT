{
    "metadata": {
        "source": "Wikibooks Cookbook",
        "url": "https://en.wikibooks.org/wiki/Cookbook:Tamil_Spice_Mix_(Milagai_Podi)",
        "title": "Cookbook:Tamil Spice Mix (Milagai Podi)",
        "cuisine_region": "South Asia",
        "type": "Recipe"
    },
    "ingredients": [
        "2 spoons red chile powder",
        "1 pinch salt",
        "1 pinch ground turmeric",
        "3 garlic cloves, crushed",
        "3 spoons ghee, melted"
    ],
    "procedure": [
        "Mix all ingredients",
        "Let sit 3 minutes."
    ]
}