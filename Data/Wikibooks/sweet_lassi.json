{
    "metadata": {
        "source": "Wikibooks Cookbook",
        "url": "https://en.wikibooks.org/wiki/Cookbook:Sweet_Lassi",
        "title": "Cookbook:Sweet Lassi",
        "cuisine_region": "South Asia",
        "type": "Recipe"
    },
    "ingredients": [
        "4 cups (1 L) yogurt",
        "3 cups (750 ml) cold water",
        "6 tbsp sugar or honey",
        "¼ tsp ground cardamom",
        "A few drops rosewater",
        "1 cup (250 ml) crushed ice"
    ],
    "procedure": [
        "Combine all ingredients except ice in blender, and blend until smooth.",
        "Add ice and continue blending until frothy."
    ]
}