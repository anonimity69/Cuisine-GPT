{
    "metadata": {
        "source": "Wikibooks Cookbook",
        "url": "https://en.wikibooks.org/wiki/Cookbook:Rava_Dosa_(Indian_Semolina_Pancake)",
        "title": "Cookbook:Rava Dosa (Indian Semolina Pancake)",
        "cuisine_region": "South Asia",
        "type": "Recipe"
    },
    "ingredients": [
        "1 cup rice flour",
        "1 cup maida (or all-purpose flour)",
        "½ cup suji (semolina flour)",
        "Salt to taste",
        "3 Indian green chiles",
        "½ tsp jeera (cumin)",
        "½ cup buttermilk",
        "Water"
    ],
    "procedure": [
        "Mix all the ingredients together to a watery batter.",
        "Heat a griddle or pan, and grease it with oil.",
        "Sprinkle the batter on the pan with your hand .",
        "Cook it on medium temperature for 3–4 minutes, or until it is completely cooked.",
        "Serve it with tomato or peanut chutney."
    ]
}