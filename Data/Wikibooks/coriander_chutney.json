{
    "metadata": {
        "source": "Wikibooks Cookbook",
        "url": "https://en.wikibooks.org/wiki/Cookbook:Coriander_Chutney",
        "title": "Cookbook:Coriander Chutney",
        "cuisine_region": "South Asia",
        "type": "Recipe"
    },
    "ingredients": [
        "1 bunch of coriander leaf (cilantro)",
        "2 or so green chillies",
        "1 tsp cumin seeds or ground cumin (optional)",
        "1 small onion",
        "1 pinch salt",
        "juice of ½ lemon or lime"
    ],
    "procedure": [
        "Wash the coriander.",
        "Finely chop the onion, chillies, and coriander.",
        "Add the salt, juice, and cumin.",
        "Blend to a fine paste."
    ]
}