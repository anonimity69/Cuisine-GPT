    "metadata": {
        "source": "Wikibooks Cookbook",
        "url": "https://en.wikibooks.org/wiki/Cookbook:Jal-jeera_(Cumin_Mango_Lemonade)",
        "title": "Cookbook:Jal-jeera (Cumin Mango Lemonade)",
        "cuisine_region": "South Asia",
        "type": "Recipe"
    },
    "ingredients": [
        "1 tsp cumin powder",
        "⅛ tsp green mango powder",
        "1 pinch Himalayan black salt",
        "¼ tsp ground mint leaves (grind to paste)",
        "1 tsp lemon juice",
        "1 cup plain soda water"
    ],
    "procedure": [
        "Combine all the ingredients in a glass.",
        "Serve."
    ]
}