{
    "metadata": {
        "source": "Wikibooks Cookbook",
        "url": "https://en.wikibooks.org/wiki/Cookbook:Masala_Chai_II",
        "title": "Cookbook:Masala Chai II",
        "cuisine_region": "South Asia",
        "type": "Recipe"
    },
    "ingredients": [
        "2 cups boiling water",
        "2 tbsp heavy cream",
        "1 bag black tea leaves",
        "2 tsp vanilla sugar",
        "½ tsp cinnamon",
        "1 pinch cocoa powder",
        "3–4 cardamom seeds",
        "1 pinch caraway seeds",
        "1 pinch anise seeds",
        "1 pinch ground ginger (optional)",
        "1 pinch ground cloves (optional)",
        "1 pinch saffron (optional)",
        "Crushed almonds (optional)"
    ],
    "procedure": [
        "Combine all ingredients in a serving cup. Steep\") for about 5 minutes.",
        "Stir vigorously to incorporate the cocoa and cinnamon.",
        "Reheat in the microwave if you prefer it very hot."
    ]
}