{
    "metadata": {
        "source": "Wikibooks Cookbook",
        "url": "https://en.wikibooks.org/wiki/Cookbook:Indian_Beans",
        "title": "Cookbook:Indian Beans",
        "cuisine_region": "South Asia",
        "type": "Recipe"
    },
    "ingredients": [
        "1 can lentils",
        "1 can kidney beans",
        "1 onion",
        "½ can tomatoes",
        "½ teaspoon paprika",
        "½ teaspoon salt",
        "½ teaspoon sugar",
        "¼ teaspoon cumin",
        "1 pinch turmeric"
    ],
    "procedure": [
        "Chop and sauté the onion.",
        "Add the tomatoes.",
        "Add all the spices.",
        "Add the lentils and kidney beans.",
        "Cook everything for 20 minutes over medium heat."
    ]
}